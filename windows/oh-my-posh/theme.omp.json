{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 3,
  "final_space": false,
  "console_title_template": "{{ .Folder }}{{ if .Root }} (admin){{ end }}",
  "palette": {
    "bg": "#1a1b26",
    "bg-dark": "#16161e",
    "fg": "#c0caf5",
    "blue": "#7aa2f7",
    "cyan": "#7dcfff",
    "green": "#9ece6a",
    "magenta": "#bb9af7",
    "red": "#f7768e",
    "yellow": "#e0af68",
    "orange": "#ff9e64",
    "teal": "#1abc9c",
    "grey": "#414868",
    "comment": "#565f89"
  },
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "os",
          "style": "diamond",
          "leading_diamond": "",
          "foreground": "p:bg",
          "background": "p:blue",
          "template": " {{ if .WSL }}WSL at {{ end }}{{ .Icon }} "
        },
        {
          "type": "session",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "p:bg",
          "background": "p:magenta",
          "template": " {{ .UserName }} "
        },
        {
          "type": "path",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "p:bg",
          "background": "p:cyan",
          "properties": {
            "style": "agnoster_short",
            "max_depth": 3,
            "home_icon": "",
            "folder_separator_icon": "  "
          },
          "template": "  {{ .Path }} "
        },
        {
          "type": "git",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "p:bg",
          "background": "p:green",
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}p:yellow{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}p:red{{ end }}",
            "{{ if gt .Ahead 0 }}p:magenta{{ end }}",
            "{{ if gt .Behind 0 }}p:orange{{ end }}"
          ],
          "properties": {
            "fetch_status": true,
            "fetch_upstream_icon": true,
            "fetch_stash_count": true,
            "branch_max_length": 25
          },
          "template": " {{ .UpstreamIcon }}{{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }}  {{ .Working.String }}{{ end }}{{ if .Staging.Changed }}  {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }}  {{ .StashCount }}{{ end }} "
        },
        {
          "type": "node",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "p:bg",
          "background": "p:green",
          "properties": { "fetch_package_manager": false, "home_enabled": false },
          "template": "  {{ .Full }} "
        },
        {
          "type": "python",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "p:bg",
          "background": "p:yellow",
          "properties": { "display_mode": "context", "home_enabled": false },
          "template": "  {{ if .Venv }}{{ .Venv }} {{ end }}{{ .Full }} "
        },
        {
          "type": "go",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "p:bg",
          "background": "p:cyan",
          "template": "  {{ .Full }} "
        },
        {
          "type": "rust",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "p:bg",
          "background": "p:orange",
          "template": "  {{ .Full }} "
        },
        {
          "type": "dotnet",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "p:bg",
          "background": "p:magenta",
          "template": "  {{ .Full }} "
        },
        {
          "type": "executiontime",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "p:bg",
          "background": "p:teal",
          "properties": { "threshold": 1000, "style": "round" },
          "template": " 󰔛 {{ .FormattedMs }} "
        },
        {
          "type": "status",
          "style": "plain",
          "foreground": "p:magenta",
          "foreground_templates": ["{{ if gt .Code 0 }}p:red{{ end }}"],
          "properties": { "always_enabled": true },
          "template": " ❯ "
        }
      ]
    }
  ],
  "transient_prompt": {
    "foreground": "p:magenta",
    "background": "transparent",
    "template": "❯ "
  },
  "secondary_prompt": {
    "foreground": "p:comment",
    "background": "transparent",
    "template": "❯❯ "
  }
}
