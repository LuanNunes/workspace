{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 3,
  "final_space": false,
  "console_title_template": "{{ .Folder }}{{ if .Root }} (admin){{ end }}",

  "//": "Estilo 'powerline discreto': blocos cinza-escuro (chrome/chrome2 alternando p/ os separadores aparecerem), UM acento no caminho, texto claro. Tudo em cores ANSI, então segue o esquema do Windows Terminal. Git colore só o TEXTO conforme o status, sem virar arco-íris de fundos.",
  "palette": {
    "accent":  "blue",
    "chrome":  "darkGray",
    "chrome2": "black",
    "text":    "foreground",
    "dark":    "black",
    "ok":      "green",
    "warn":    "yellow",
    "err":     "red",
    "muted":   "darkGray"
  },

  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "os",
          "style": "diamond",
          "leading_diamond": "",
          "foreground": "p:accent",
          "background": "p:chrome2",
          "template": " {{ if .WSL }}WSL {{ end }}{{ .Icon }} "
        },
        {
          "type": "session",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "p:text",
          "background": "p:chrome",
          "template": " {{ .UserName }} "
        },
        {
          "type": "path",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "p:dark",
          "background": "p:accent",
          "properties": {
            "style": "agnoster_short",
            "max_depth": 3,
            "home_icon": "",
            "folder_separator_icon": "  "
          },
          "template": "  {{ .Path }} "
        },
        {
          "type": "git",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "p:ok",
          "background": "p:chrome",
          "foreground_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}p:warn{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}p:err{{ end }}",
            "{{ if gt .Behind 0 }}p:warn{{ end }}"
          ],
          "properties": {
            "fetch_status": true,
            "fetch_upstream_icon": true,
            "fetch_stash_count": true,
            "branch_max_length": 25
          },
          "template": " {{ .UpstreamIcon }}{{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }}  {{ .Working.String }}{{ end }}{{ if .Staging.Changed }}  {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }}  {{ .StashCount }}{{ end }} "
        },
        {
          "type": "node",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "p:ok",
          "background": "p:chrome2",
          "properties": { "fetch_package_manager": false, "home_enabled": false },
          "template": "  {{ .Full }} "
        },
        {
          "type": "python",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "p:warn",
          "background": "p:chrome",
          "properties": { "display_mode": "context", "home_enabled": false },
          "template": "  {{ if .Venv }}{{ .Venv }} {{ end }}{{ .Full }} "
        },
        {
          "type": "go",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "p:accent",
          "background": "p:chrome2",
          "template": "  {{ .Full }} "
        },
        {
          "type": "rust",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "p:text",
          "background": "p:chrome",
          "template": "  {{ .Full }} "
        },
        {
          "type": "dotnet",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "p:text",
          "background": "p:chrome2",
          "template": "  {{ .Full }} "
        },
        {
          "type": "executiontime",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "p:muted",
          "background": "p:chrome",
          "properties": { "threshold": 1000, "style": "round" },
          "template": " 󰔛 {{ .FormattedMs }} "
        },
        {
          "type": "status",
          "style": "plain",
          "foreground": "p:ok",
          "foreground_templates": ["{{ if gt .Code 0 }}p:err{{ end }}"],
          "properties": { "always_enabled": true },
          "template": " ❯ "
        }
      ]
    }
  ],

  "transient_prompt": {
    "foreground": "p:accent",
    "background": "transparent",
    "template": "❯ "
  },
  "secondary_prompt": {
    "foreground": "p:muted",
    "background": "transparent",
    "template": "❯❯ "
  }
}
