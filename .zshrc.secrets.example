# Copy this file to ~/.zshrc.secrets and fill in real values:
#   cp ~/dotfiles/.zshrc.secrets.example ~/.zshrc.secrets && chmod 600 ~/.zshrc.secrets
# ~/.zshrc sources ~/.zshrc.secrets automatically. Never commit the real file.

export OPENAI_API_KEY="sk-proj-REPLACE_ME"
export ANTHROPIC_API_KEY="sk-ant-REPLACE_ME"
